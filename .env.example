# CockroachDB Cloud (agent service account — grants on agent-visible tables ONLY)
CRDB_URL=postgresql://coldcase_agent:PASSWORD@CLUSTER.cockroachlabs.cloud:26257/coldcase?sslmode=verify-full

# Separate admin/judge connection (ingestion + scoring; has judge schema access)
CRDB_ADMIN_URL=postgresql://coldcase_admin:PASSWORD@CLUSTER.cockroachlabs.cloud:26257/coldcase?sslmode=verify-full

# AWS
AWS_REGION=us-east-1
BEDROCK_AGENT_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0
BEDROCK_SYNTH_MODEL=us.anthropic.claude-sonnet-5-v1:0
BEDROCK_EMBED_MODEL=amazon.titan-embed-text-v2:0
S3_BUCKET=coldcase-corpus

# Agent
MAX_TOOL_CALLS_PER_SESSION=50
CASE_ID=
